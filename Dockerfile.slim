# Distroless 기반 초경량 런타임 이미지

# 1) 프로덕션 의존성만 설치
FROM node:22-alpine AS deps
WORKDIR /app
COPY package.json yarn.lock ./
RUN yarn install --production=true --frozen-lockfile --ignore-optional --non-interactive --no-progress \
  && yarn cache clean \
  && rm -rf /root/.cache /usr/local/share/.cache /tmp/*

# 2) 빌드 (devDeps 포함)
FROM node:22-alpine AS builder
WORKDIR /app
COPY package.json yarn.lock ./
RUN yarn install --frozen-lockfile --non-interactive --no-progress
COPY . .
RUN yarn build

# 3) 런타임: distroless (nonroot)
FROM gcr.io/distroless/nodejs22-debian12:nonroot AS runtime
WORKDIR /app
ENV NODE_ENV=production
ENV TZ=Asia/Seoul

COPY --from=deps /app/node_modules ./node_modules
COPY --from=builder /app/dist ./dist
EXPOSE 3000
# distroless nodejs 이미지는 entrypoint가 node로 설정되어 있음
CMD ["dist/main.js"]


